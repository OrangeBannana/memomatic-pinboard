[Unit]
Description=Memomatic Pinboard web app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=memomatic
WorkingDirectory=/home/memomatic/pinboard/app
Environment=PINBOARD_HOME=/home/memomatic/pinboard
Environment=PINBOARD_SLIDE_SECONDS=15
Environment=PINBOARD_OWNER_TOKEN=memes
ExecStart=/usr/bin/python3 -m uvicorn app:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
